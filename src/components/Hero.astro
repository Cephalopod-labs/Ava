---
---

<section class="hero">
	<div class="hero-overlay"></div>
	<div class="hero-content">
		<p class="hero-pre animate-fade-in-up delay-1">Nueva Colección 2026</p>
		<h1 class="hero-title animate-fade-in-up delay-2">
			Diseñada para<br />
			<em>resaltar tu belleza</em>
		</h1>
		<p class="hero-subtitle animate-fade-in-up delay-3">
			Trajes de baño únicos que combinan elegancia, comodidad y estilo para cada momento bajo el sol.
		</p>
		<a href="#productos" class="hero-cta animate-fade-in-up delay-4">
			Explorar colección
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none">
				<path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</div>

	<div class="hero-scroll-indicator animate-fade-in delay-6">
		<div class="scroll-line"></div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		background: linear-gradient(135deg, var(--seashell) 0%, var(--alabaster-grey-2) 50%, var(--pale-slate) 100%);
		overflow: hidden;
	}

	.hero::before {
		content: '';
		position: absolute;
		top: -50%;
		right: -30%;
		width: 80%;
		height: 200%;
		background: radial-gradient(ellipse, rgba(247, 237, 235, 0.6) 0%, transparent 70%);
		animation: floatBg 15s ease-in-out infinite;
	}

	.hero::after {
		content: '';
		position: absolute;
		bottom: -30%;
		left: -20%;
		width: 60%;
		height: 160%;
		background: radial-gradient(ellipse, rgba(220, 219, 218, 0.4) 0%, transparent 70%);
		animation: floatBg 20s ease-in-out infinite reverse;
	}

	@keyframes floatBg {
		0%, 100% { transform: translate(0, 0) rotate(0deg); }
		33% { transform: translate(30px, -20px) rotate(2deg); }
		66% { transform: translate(-20px, 15px) rotate(-1deg); }
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 20% 80%, rgba(146, 137, 145, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 80% 20%, rgba(187, 183, 187, 0.15) 0%, transparent 50%);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
		padding: 2rem;
		max-width: 700px;
	}

	.hero-pre {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--rosy-granite);
		margin-bottom: 1.5rem;
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 300;
		line-height: 1.15;
		color: var(--text-dark);
		margin-bottom: 1.5rem;
	}

	.hero-title em {
		font-style: italic;
		font-weight: 300;
		color: var(--rosy-granite);
	}

	.hero-subtitle {
		font-size: 1.05rem;
		font-weight: 300;
		line-height: 1.7;
		color: var(--text-medium);
		max-width: 480px;
		margin: 0 auto 2.5rem;
	}

	.hero-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2.5rem;
		background: var(--text-dark);
		color: var(--seashell);
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		border-radius: 50px;
		transition: all 0.4s ease;
	}

	.hero-cta:hover {
		background: var(--rosy-granite);
		transform: translateY(-2px);
		box-shadow: 0 10px 30px rgba(146, 137, 145, 0.3);
	}

	.hero-cta svg {
		transition: transform 0.3s ease;
	}

	.hero-cta:hover svg {
		transform: translateX(4px);
	}

	.hero-scroll-indicator {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 2;
	}

	.scroll-line {
		width: 1px;
		height: 50px;
		background: linear-gradient(to bottom, var(--rosy-granite), transparent);
		animation: scrollPulse 2s ease-in-out infinite;
	}

	@keyframes scrollPulse {
		0%, 100% { opacity: 0.3; transform: scaleY(1); }
		50% { opacity: 1; transform: scaleY(1.3); }
	}

	@media (max-width: 768px) {
		.hero-subtitle {
			font-size: 0.95rem;
		}
	}
</style>
