---
---

<header class="header animate-slide-down">
	<div class="header-inner">
		<a href={import.meta.env.BASE_URL} class="logo">
			<span class="logo-text">Ava</span>
			<span class="logo-tagline">swimwear</span>
		</a>

		<nav class="nav">
			<a href="#productos" class="nav-link">Colección</a>
			<a href="#nosotros" class="nav-link">Nosotros</a>
			<a href="#contacto" class="nav-link">Contacto</a>
		</nav>

		<button class="menu-toggle" aria-label="Abrir menú" id="menuToggle">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>

	<nav class="mobile-nav" id="mobileNav">
		<a href="#productos" class="mobile-nav-link">Colección</a>
		<a href="#nosotros" class="mobile-nav-link">Nosotros</a>
		<a href="#contacto" class="mobile-nav-link">Contacto</a>
	</nav>
</header>

<script>
	const toggle = document.getElementById('menuToggle');
	const mobileNav = document.getElementById('mobileNav');

	toggle?.addEventListener('click', () => {
		toggle.classList.toggle('active');
		mobileNav?.classList.toggle('open');
	});

	document.querySelectorAll('.mobile-nav-link').forEach(link => {
		link.addEventListener('click', () => {
			toggle?.classList.remove('active');
			mobileNav?.classList.remove('open');
		});
	});
</script>

<style>
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(247, 237, 235, 0.85);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(187, 183, 187, 0.2);
	}

	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		display: flex;
		flex-direction: column;
		align-items: center;
		line-height: 1;
	}

	.logo-text {
		font-family: var(--font-serif);
		font-size: 2rem;
		font-weight: 300;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--text-dark);
	}

	.logo-tagline {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--text-light);
		font-weight: 300;
	}

	.nav {
		display: flex;
		gap: 2.5rem;
	}

	.nav-link {
		font-size: 0.85rem;
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-medium);
		transition: color 0.3s ease;
		position: relative;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--rosy-granite);
		transition: width 0.3s ease;
	}

	.nav-link:hover {
		color: var(--text-dark);
	}

	.nav-link:hover::after {
		width: 100%;
	}

	.menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		padding: 4px;
	}

	.menu-toggle span {
		display: block;
		width: 24px;
		height: 1.5px;
		background: var(--text-dark);
		transition: all 0.3s ease;
		transform-origin: center;
	}

	.menu-toggle.active span:nth-child(1) {
		transform: rotate(45deg) translate(4.5px, 4.5px);
	}

	.menu-toggle.active span:nth-child(2) {
		opacity: 0;
	}

	.menu-toggle.active span:nth-child(3) {
		transform: rotate(-45deg) translate(4.5px, -4.5px);
	}

	.mobile-nav {
		display: none;
		flex-direction: column;
		padding: 0 2rem 1.5rem;
		gap: 1rem;
	}

	.mobile-nav.open {
		display: flex;
	}

	.mobile-nav-link {
		font-size: 0.9rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-medium);
		padding: 0.5rem 0;
		border-bottom: 1px solid rgba(187, 183, 187, 0.2);
		transition: color 0.3s ease;
	}

	.mobile-nav-link:hover {
		color: var(--text-dark);
	}

	@media (max-width: 768px) {
		.nav {
			display: none;
		}

		.menu-toggle {
			display: flex;
		}
	}
</style>
